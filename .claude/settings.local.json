  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "curl -fsS -m 1 -X POST http://127.0.0.1:7321/status/working > /dev/null 2>&1 || true",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "curl -fsS -m 1 -X POST http://127.0.0.1:7321/status/ready > /dev/null 2>&1 || true",
            "timeout": 3
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/notify-status.mjs\"",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "curl -fsS -m 1 -X POST http://127.0.0.1:7321/status/working > /dev/null 2>&1 || true",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "curl -fsS -m 1 -X POST http://127.0.0.1:7321/status/working > /dev/null 2>&1 || true",
            "timeout": 3
          }
        ]
      }
    ]
  }
