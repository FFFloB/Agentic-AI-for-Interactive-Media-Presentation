      "Bash(curl -sS -L -o obsidian.svg \"https://obsidian.md/images/obsidian-logo-gradient.svg\")",
      "Bash(npm run *)",
      "Bash(mkdir -p src/assets/logos)",
      "Bash(mv public/logos/* src/assets/logos/)",
      "Bash(rmdir public/logos)",
      "Bash(jobs *)",
      "Bash(powershell.exe -NoProfile -Command \"Get-CimInstance Win32_Process -Filter \\\\\"Name='node.exe' OR Name='cmd.exe' OR Name='bash.exe'\\\\\" | Select-Object ProcessId, Name, CommandLine | Format-List\")",
      "Bash(curl *)",
      "Bash(grep -v \"^$\")",
      "Bash(powershell.exe -Command \"Get-NetTCPConnection -LocalPort 5180 -ErrorAction SilentlyContinue | Select-Object -First 2 LocalAddress, LocalPort, OwningProcess, State\")",
      "Bash(powershell.exe -Command 'Get-NetTCPConnection -LocalPort 5180 -State Listen -ErrorAction SilentlyContinue | Select-Object LocalAddress, LocalPort, OwningProcess | Format-Table -AutoSize; Write-Host '\\\\''---process---'\\\\''; Get-NetTCPConnection -LocalPort 5180 -State Listen -ErrorAction SilentlyContinue | ForEach-Object { Get-Process -Id $_.OwningProcess -ErrorAction SilentlyContinue | Select-Object Id, ProcessName, Path | Format-List }')",
      "Bash(powershell.exe -Command \"Stop-Process -Id 67884 -Force; Start-Sleep -Milliseconds 500; if \\(Get-NetTCPConnection -LocalPort 5180 -State Listen -ErrorAction SilentlyContinue\\) { Write-Host 'still listening' } else { Write-Host 'port 5180 clear' }\")"
    ]
